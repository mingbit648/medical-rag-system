# ---------------------------
# 1️⃣ 构建阶段
# ---------------------------
FROM node:18-alpine AS builder

WORKDIR /app

# 安装依赖
COPY package*.json ./
RUN npm ci

# 拷贝源码
COPY . .

# 生产环境变量
# API 地址使用相对路径，由 Nginx 代理，IP 变化无需重新构建
# Dify API Key 已迁移到后端，前端不再需要配置

# 设置生产环境
ENV NODE_ENV=production

# 构建静态文件
RUN npm run build

# ---------------------------
# 2️⃣ 运行阶段：使用 Nginx 提供静态文件服务
# ---------------------------
FROM nginx:alpine

# 拷贝静态导出文件到 Nginx
COPY --from=builder /app/out /usr/share/nginx/html

# 拷贝自定义 Nginx 配置
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 3000

CMD ["nginx", "-g", "daemon off;"]

