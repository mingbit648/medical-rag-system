# ========================================
# 法律辅助咨询 RAG 系统 - 环境变量配置
# 复制此文件为 .env 并填入实际值
# ========================================

# ========================================
# 基础配置
# ========================================
ENVIRONMENT=development
DEBUG=true

# ========================================
# 数据库配置 (PostgreSQL)
# ========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=legal_rag
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/legal_rag

# ========================================
# Docker 构建选项
# ========================================
BACKEND_INSTALL_ML=false

# ========================================
# 向量存储配置（默认 memory，ML 模式可改为 chroma）
# ========================================
VECTOR_DB_BACKEND=memory
CHROMA_PERSIST_DIR=/app/data/chroma
CHROMA_COLLECTION_NAME=legal_chunks

# ========================================
# DeepSeek API 配置（必填）
# ========================================
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ========================================
# SiliconFlow API 配置（Embedding + Rerank）
# ========================================
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_EMBED_MODEL=BAAI/bge-large-zh-v1.5
SILICONFLOW_RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ========================================
# Provider 选择
# ========================================
# Embedding: siliconflow / sentence-transformers / hash
EMBEDDING_PROVIDER=siliconflow
# Rerank: siliconflow / cross-encoder
RERANK_PROVIDER=siliconflow



